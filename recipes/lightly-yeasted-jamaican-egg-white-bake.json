    {
      "name": "Large egg whites",
      "amount": "6",
      "notes": "Room temperature"
    },
    {
      "name": "Cooked rest-meat (e.g. chicken or turkey)",
      "amount": "8 oz"
    },
    {
      "name": "Yeast",
      "amount": "1 tsp"
    },
    {
      "name": "Salt",
      "amount": "1/4 tsp"
    },
    {
      "name": "Black pepper",
      "amount": "1/8 tsp"
    },
    {
      "name": "Coconut oil",
      "amount": "2 tbsp"
    },
    {
      "name": "Dried thyme",
      "amount": "1 tsp"
    },
    {
      "name": "Dried oregano",
      "amount": "1 tsp"
    },
    {
      "name": "Garlic powder",
      "amount": "1 tsp"
    },
    {
      "name": "Crushed red pepper flakes",
      "amount": "1/4 tsp"
    }
  ],
  "instructions": [
    "Preheat your oven to 350°F (175°C).",
    "In a medium bowl, whisk together egg whites, yeast, salt, black pepper, and garlic powder.",
    "Add the cooked rest-meat, coconut oil, dried thyme, dried oregano, and crushed red pepper flakes to the bowl. Mix until well combined.",
    "Pour the egg-white mixture into a greased 9x9-inch baking dish.",
    "Bake for 25 minutes, or until the edges are lightly golden brown and the center is set.",
    "Remove from the oven and let cool for 5 minutes.",
    "Slice into 6-8 squares and serve hot."
  ],
