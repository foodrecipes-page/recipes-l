{
  "title": "Light Algerian Navy Bean Tagine",
  "description": "A floral and snappy weeknight Algerian dish featuring dried white navy beans, sashimi-cut and kosher-friendly, served in a dolsot-stone-bowl.",
  "cuisine": "Algerian",
  "diet": [
    "kosher"
  ],
