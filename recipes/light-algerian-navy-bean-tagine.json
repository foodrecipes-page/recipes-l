  "ingredients": [
    {
      "name": "dried white navy beans",
      "amount": "1 cup",
      "notes": "soaked overnight and drained"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "thinly sliced"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "ground cumin",
      "amount": "1 teaspoon"
    },
    {
      "name": "paprika",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "chicken broth",
      "amount": "2 cups"
    },
    {
      "name": "fresh parsley",
      "amount": "1/4 cup",
      "notes": "chopped"
    },
    {
      "name": "lemon juice",
      "amount": "2 tablespoons"
    }
  ],
  "instructions": [
    "Heat the olive oil in the dolsot-stone-bowl over medium heat.",
    "Add the sliced onion and cook until it is translucent and starting to caramelize.",
    "Add the minced garlic and cook for 1 minute, stirring constantly to prevent burning.",
    "Stir in the ground cumin, paprika, salt, and black pepper, and cook for 1 minute.",
    "Add the soaked and drained navy beans, chicken broth, and chopped parsley to the bowl.",
    "Bring the mixture to a boil, then reduce the heat to low and simmer, covered, for 20 minutes, or until the beans are tender.",
    "Stir in the lemon juice and cook for an additional 2 minutes.",
    "Serve the tagine hot, garnished with additional parsley if desired."
  ],
