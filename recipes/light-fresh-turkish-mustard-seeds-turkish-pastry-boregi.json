    },
    {
      "name": "flaxseed meal",
      "amount": "1 tablespoon",
      "notes": "as egg substitute"
    }
  ],
  "instructions": [
    "preheat oven to 375f (190c).",
    "roll out the turkish pastry dough to a thickness of 1/8 inch.",
    "mix together the mustard seeds, dashi extract, sunflower seeds, parsley, lemon juice, olive oil, salt, and black pepper in a small bowl.",
    "brush the edges of the dough with water and sprinkle with flaxseed meal.",
    "place the dough on a baking sheet lined with parchment paper and spread the mustard seed mixture evenly over the dough.",
    "fold the dough over the filling to form a triangle and press the edges to seal.",
    "bake for 20-25 minutes or until golden brown.",
    "let cool for 5 minutes before slicing and serving."
  ],
