    {
      "name": "mussels",
      "amount": "2 pounds",
      "notes": "scrubbed and debearded"
    },
    {
      "name": "smoked paprika",
      "amount": "2 tablespoons"
    },
    {
      "name": "onion",
      "amount": "1 medium"
    },
    {
      "name": "garlic",
      "amount": "3 cloves"
    },
    {
      "name": "tomato",
      "amount": "2 medium"
    },
    {
      "name": "coconut milk",
      "amount": "1 can"
    },
    {
      "name": "vegetable oil",
      "amount": "1/4 cup"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "fresh cilantro",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Rinse the mussels under cold water and discard any broken shells",
    "Heat the oil in a large pot over medium heat",
    "Add the onion and garlic and cook until the onion is translucent",
    "Add the smoked paprika and cook for 1 minute",
    "Add the tomato and cook for 2 minutes",
    "Add the mussels and cook until they start to open",
    "Add the coconut milk and bring to a boil",
    "Reduce the heat to low and simmer for 5 minutes",
    "Season with salt and black pepper to taste",
    "Garnish with chopped cilantro and serve hot"
  ],
