{
  "title": "Croatian Pastry Pilaf",
  "description": "A traditional Croatian dish featuring flaky pastry and a savory pilaf, perfect for a hangover cure. This version is dairy-free friendly and packed with umami flavor.",
  "cuisine": "Croatian",
  "diet": [
    "dairy-free",
    "vegetarian"
