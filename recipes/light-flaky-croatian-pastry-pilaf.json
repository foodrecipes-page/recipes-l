  "ingredients": [
    {
      "name": "all-purpose flour",
      "amount": "2 cups",
      "notes": "for pastry"
    },
    {
      "name": "malai",
      "amount": "1/2 cup",
      "notes": "or non-dairy yogurt"
    },
    {
      "name": "brine-dried vegetables",
      "amount": "1 cup",
      "notes": "such as carrots and zucchini"
    },
    {
      "name": "mushrooms",
      "amount": "1 cup",
      "notes": "sliced"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Preheat oven to 375 degrees.",
    "In a large bowl, whisk together flour and salt.",
    "Add malai and mix until a dough forms.",
    "Roll out the dough to a thickness of 1/8 inch.",
    "Cut into squares and layer in a baking dish.",
    "In a separate pan, saute the mushrooms and onion in olive oil.",
    "Add brine-dried vegetables and cook until heated through.",
    "Spoon the pilaf mixture over the pastry layers.",
    "Bake for 25 minutes or until the pastry is golden brown."
  ],
