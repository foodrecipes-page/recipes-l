      "name": "quinoa",
      "amount": "1 cup"
    },
    {
      "name": "cooked brown rice",
      "amount": "1/2 cup"
    },
    {
      "name": "scallions (green onions)",
      "amount": "8-10 pieces"
    },
    {
      "name": "soy sauce",
      "amount": "3 tablespoons"
    },
    {
      "name": "sesame oil",
      "amount": "1 tablespoon"
    },
    {
      "name": "red pepper flakes",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "salt",
      "amount": "to taste"
    },
    {
      "name": "crumbled feta cheese (optional)",
      "amount": "30g"
    }
  ],
  "instructions": [
    "Rinse quinoa under cold water and cook according to package instructions, then let it cool.",
    "In a wok or large frying pan, heat sesame oil over medium-high heat.",
    "Add scallions, red pepper flakes, and salt. Stir-fry for about 2 minutes until fragrant and slightly softened.",
    "Stir in cooked quinoa and cooked brown rice together with soy sauce. Mix well to combine all ingredients.",
    "If using feta cheese, add it towards the end of cooking along with any additional seasonings you like (e.g., garlic powder).",
    "Serve immediately while hot."
  ],
