    },
    {
      "name": "Onion, finely chopped",
      "amount": "1"
    },
    {
      "name": "Bell Pepper, sliced",
      "amount": "1 cup"
    },
    {
      "name": "Cilantro (optional for garnish)",
      "amount": "handful"
    }
  ],
  "instructions": [
    "Heat oil in a pan over medium heat.",
    "Add chopped onions and bell pepper slices. Stir-fry until the vegetables are slightly softened, about 5 minutes.",
    "Stir in cocoa powder and bhuna masala. Mix well to combine all ingredients.",
    "Reduce heat to low, let it simmer for another minute or two until the flavors are well combined.",
    "Serve hot with a side of fresh cilantro if desired."
