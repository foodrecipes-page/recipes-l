  "title": "Lazy Sunday Spicy Fry",
  "description": "A lazy Sunday Canadian dish featuring a spicy fry with light rum, ideal for a casual keto-friendly meal.",
  "cuisine": "Canadian",
  "diet": [
    "keto"
  ],
  "meal": "snack",
  "ingredients": [
    {
      "name": "ground beef",
      "amount": "1 cup"
    },
    {
      "name": "onion, finely chopped",
      "amount": "1/4 cup"
    },
    {
      "name": "bell pepper, diced",
      "amount": "1/2 cup"
    },
    {
      "name": "garlic cloves, minced",
      "amount": "3 cloves"
    },
    {
      "name": "hot sauce (e.g. sriracha)",
      "amount": "1 tablespoon"
    },
    {
      "name": "light rum",
      "amount": "1/4 cup"
    },
    {
      "name": "salt and pepper",
      "notes": "to taste"
    },
    {
      "name": "ground cumin",
      "amount": "1 teaspoon"
    },
    {
      "name": "bell pepper, chopped for garnish (optional)",
      "amount": "a few leaves"
    },
    {
      "name": "paprika, for garnish (optional)",
      "amount": "optional"
    }
  ],
  "instructions": [
    "In a large skillet, heat olive oil over medium-high heat.",
    "Add ground beef and cook until browned, breaking it up with a spoon as it cooks. Season with salt and pepper.",
    "Add onions, bell peppers, and garlic; sauté for about 5 minutes or until softened.",
    "Stir in hot sauce and rum. Continue to stir until the liquid has mostly evaporated.",
    "Taste and adjust seasoning as necessary with additional salt or pepper.",
    "Garnish with chopped bell pepper leaves and a sprinkle of paprika if desired.",
    "Serve immediately while still warm."
  ],
