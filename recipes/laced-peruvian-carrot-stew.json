      "amount": "1 teaspoon"
    },
    {
      "name": "salt",
      "amount": "to taste"
    },
    {
      "name": "black pepper",
      "amount": "to taste"
    },
    {
      "name": "cilantro",
      "amount": "1 bunch",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Heat olive oil in a large pot over medium heat.",
    "Add diced onion, minced garlic, and toasted mustard seeds, sautéing until the onion softens.",
    "Stir in sliced carrots and dried oregano, cooking for 3 minutes.",
    "Pour in chicken stock, bring to a boil, then reduce heat and simmer for 15 minutes until carrots are tender.",
    "Season the stew with lime juice, salt, and pepper, stirring to combine.",
    "Fold in chopped cilantro just before serving.",
    "Sprinkle toasted pumpkin seeds over each bowl to add a crumbly crunch."
  ],
