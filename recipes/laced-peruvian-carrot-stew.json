      "amount": "3",
      "notes": "minced"
    },
    {
      "name": "mustard seeds",
      "amount": "1 tablespoon",
      "notes": "toasted"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "chicken stock",
      "amount": "4 cups"
    },
    {
