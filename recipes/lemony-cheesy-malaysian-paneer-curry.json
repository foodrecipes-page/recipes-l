{
  "title": "Lemony Cheesy Malaysian Paneer Curry",
  "description": "A vibrant citrusy curry with paneer, black olives and a creamy coconut base, perfect for a crowd-pleasing, lacto-vegetarian Malaysian feast.",
  "cuisine": "Malaysian",
  "diet": [
    "lacto-vegetarian"
  ],
