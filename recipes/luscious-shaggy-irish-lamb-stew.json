{
  "title": "Luscious Shaggy Irish Lamb Stew",
  "description": "A hearty and flavorful Irish lamb stew cooked in a clay pot, wrapped in corn husks, and featuring the warmth of cumin, perfect for a weeknight dinner.",
  "cuisine": "Irish",
  "diet": [
    "whole30"
  ],
