    {
      "name": "lamb shoulder",
      "amount": "2 pounds",
      "notes": "fat trimmed, cut into 2-inch pieces"
    },
    {
      "name": "onion",
      "amount": "1 large",
      "notes": "chopped"
    },
    {
      "name": "carrots",
      "amount": "4 medium",
      "notes": "peeled, chopped"
    },
    {
      "name": "potatoes",
      "amount": "2 large",
      "notes": "peeled, chopped"
    },
    {
      "name": "cumin",
      "amount": "2 teaspoons",
      "notes": "ground"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "chicken broth",
      "amount": "2 cups"
    },
    {
      "name": "corn husks",
      "amount": "4-6",
      "notes": "for wrapping the clay pot"
    }
  ],
  "instructions": [
    "Preheat the oven to 300 degrees Fahrenheit.",
    "Season the lamb pieces with salt, black pepper, and cumin.",
    "In a large clay pot, combine the lamb, onion, carrots, and potatoes.",
    "Pour in the chicken broth, making sure that all the ingredients are covered.",
    "Wrap the clay pot in corn husks, securing them with kitchen twine if necessary.",
    "Place the wrapped clay pot in the oven and cook for 2 1/2 hours.",
    "Remove the pot from the oven and let it cool for a few minutes before unwrapping and serving.",
    "Serve the stew hot, garnished with fresh herbs if desired."
  ],
