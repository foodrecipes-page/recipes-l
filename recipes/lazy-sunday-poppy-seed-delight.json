{
  "title": "Lazy Sunday Poppy Seed Delight",
  "description": "A nutty and juicy poppy seed delight for a lazy Sunday, featuring air-fried ground poppy seeds that is diabetic-friendly and easy to prepare.",
  "cuisine": "Middle Eastern",
  "diet": [
    "diabetic-friendly"
  ],
  "meal": "dessert",
  "ingredients": [
    {
      "name": "Poppy Seeds",
      "amount": "1 cup"
    },
    {
      "name": "Water or Vegetable Stock",
      "amount": "2 cups"
    },
    {
      "name": "Olive Oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "Turmeric Powder",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "Salt",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "Ground Almonds or Nut Butter",
      "amount": "1/3 cup"
    }
  ],
  "instructions": [
    "Preheat your air fryer to 375\u00b0F (190\u00b0C).",
    "Mix the poppy seeds, water, olive oil, turmeric powder, and salt in a large bowl.",
    "Stir until all the poppy seeds are well coated with the mixture.",
    "Fold in ground almonds or nut butter for added texture and flavor.",
    "Spoon the mixture into an air fryer basket lined with parchment paper to prevent sticking.",
    "Air-fry on high for about 15-20 minutes, turning occasionally until golden brown and crispy.",
    "Let cool slightly before serving."
  ],
