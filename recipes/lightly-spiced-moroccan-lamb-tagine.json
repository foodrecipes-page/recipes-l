{
  "title": "Lightly Spiced Moroccan Lamb Tagine",
  "description": "A tangy and crumbly Moroccan dish featuring lamb, served with sesame seed burger buns, cooked in a ttukbaegi earthenware pot, and free from onions and garlic.",
  "cuisine": "Moroccan",
  "diet": [
    "gluten-free",
    "halal"
  ],
  "meal": "lunch",
  "ingredients": [
    {
      "name": "lamb shoulder",
      "amount": "1 pound",
      "notes": "cut into 1 inch pieces"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "ground cumin",
      "amount": "1 teaspoon"
    },
    {
      "name": "ground coriander",
      "amount": "1 teaspoon"
    },
    {
      "name": "paprika",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "cayenne pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "chicken broth",
      "amount": "1 cup"
    },
    {
      "name": "dried apricots",
      "amount": "1/2 cup"
    },
    {
      "name": "sesame seed burger buns",
      "amount": "4 buns"
    }
  ],
  "instructions": [
    "Heat the olive oil in the ttukbaegi earthenware pot over medium heat.",
    "Add the lamb pieces and cook until browned on all sides.",
    "Add the cumin, coriander, paprika, cayenne pepper, salt, and black pepper, and stir to combine.",
    "Pour in the chicken broth and bring to a boil.",
    "Reduce the heat to low and simmer, covered, for 1 1/2 hours.",
    "Stir in the dried apricots and continue to simmer for another 30 minutes.",
    "Split the sesame seed burger buns in half and toast until lightly browned.",
    "Serve the lamb tagine in the toasted buns.",
    "Garnish with fresh parsley or cilantro, if desired.",
    "Serve immediately and enjoy."
  ],
