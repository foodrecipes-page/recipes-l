    },
    {
      "name": "vegetable oil",
      "amount": "2 tbsp",
      "notes": "for sautéing"
    }
  ],
  "instructions": [
    "Heat oil in a wide, shallow bamboo tray over medium heat.",
    "Add chopped onion, garlic, and ginger, sauté until translucent and aromatic.",
    "Stir in cumin, coriander, and turmeric, cooking for 30 seconds until fragrant.",
    "Add diced tomatoes and cook until softened, about 5 minutes.",
    "Pour in rinsed lentils and coconut milk, stirring to combine.",
    "Bring to a gentle boil, then reduce heat to low and simmer, covering partially, for 20 minutes until lentils are tender.",
    "Add tofu cubes and fresh parsley, simmer for an additional 5 minutes until tofu is heated through.",
    "Season with garam masala and salt to taste, then serve hot with steamed rice or naan."
  ],
