      "amount": "1 large",
      "notes": "peeled and sliced"
    },
    {
      "name": "Chopped fresh cilantro",
      "amount": "2 tablespoons",
      "notes": "optional"
    },
    {
      "name": "Salt",
      "amount": "1/4 teaspoon",
      "notes": "or to taste"
    },
    {
