{
  "title": "Uruguayan Brussels Sprouts Pilaf",
  "description": "A delicious and nutritious Uruguayan-inspired pilaf featuring Brussels sprouts, carrots, and onions, all cooked to perfection in a flavorful broth.",
  "cuisine": "Uruguayan",
  "diet": [
    "vegetarian",
