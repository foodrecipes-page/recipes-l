{
  "title": "Lemon Light British Lentils Curry",
  "description": "A bright, citrusy vegan curry that uses sesame seed oil and a quick temper to give a snappy, kid-friendly bite.",
  "cuisine": "British",
  "diet": [
    "vegan"
  ],
  "meal": "dinner",
