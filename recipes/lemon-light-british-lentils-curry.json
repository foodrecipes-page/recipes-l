      "name": "red lentils",
      "amount": "1 cup (200g)",
      "notes": "rinsed"
    },
    {
      "name": "vegetable broth",
      "amount": "1 1/2 cups (360ml)"
    },
    {
      "name": "diced tomatoes",
      "amount": "1 cup (240ml)"
    },
    {
      "name": "onion",
      "amount": "1 small, finely chopped"
    },
    {
      "name": "garlic cloves",
      "amount": "2, minced"
    },
    {
      "name": "fresh ginger",
      "amount": "1 tbsp, grated"
    },
    {
      "name": "ground cumin",
      "amount": "1 tsp"
    },
    {
      "name": "ground turmeric",
      "amount": "1 tsp"
    },
    {
