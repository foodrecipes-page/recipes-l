{
  "title": "Lean Dutch Chicken Roast",
  "description": "A savory, light Dutch oven chicken roast featuring a splash of Appleton Rum, perfect for a post‑workout meal that stays diabetic‑friendly.",
  "cuisine": "Dutch",
  "diet": [
    "low-carb",
    "diabetic-friendly",
    "gluten-free",
    "paleo"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "boneless skinless chicken breasts",
      "amount": "4 (about 1 ½ lb total)",
      "notes": "sliced into 1‑inch pieces"
    },
    {
      "name": "olive oil",
      "amount": "1 tbsp"
    },
    {
      "name": "Appleton Rum",
      "amount": "2 tbsp"
    },
    {
      "name": "Dijon mustard",
      "amount": "2 tbsp"
    },
    {
      "name": "honey or monkfruit sweetener",
      "amount": "1 tbsp"
    },
    {
      "name": "smoked paprika",
      "amount": "1 tsp"
    },
    {
      "name": "dried thyme",
      "amount": "1 tsp"
    },
    {
      "name": "garlic powder",
      "amount": "1 tsp"
    },
    {
      "name": "sea salt",
      "amount": "1 tsp"
    },
    {
      "name": "black pepper",
      "amount": "½ tsp"
    },
    {
      "name": "low‑sodium chicken broth",
      "amount": "1 cup"
    },
    {
      "name": "apple",
      "amount": "1 medium, thinly sliced"
    }
  ],
  "instructions": [
    "Preheat oven to 375°F (190°C).",
    "Heat the olive oil in a Dutch oven over medium heat.",
    "Add the chicken pieces and brown lightly on all sides, about 5 minutes.",
    "Stir in the Appleton Rum, Dijon mustard, honey, smoked paprika, thyme, garlic powder, salt, and pepper; cook for 2 minutes until fragrant.",
    "Pour in the chicken broth and add the apple slices, stirring to combine.",
    "Bring the mixture to a gentle simmer, then cover the pot and transfer to the preheated oven.",
    "Roast for 45 minutes, or until the chicken reaches 165°F (74°C) and the apples are tender.",
    "Remove from oven, let rest 5 minutes, then serve hot with a side of steamed broccoli or cauliflower rice if desired."
  ],
