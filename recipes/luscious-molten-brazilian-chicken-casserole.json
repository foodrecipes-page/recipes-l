{
  "title": "Luscious Molten Brazilian Chicken Casserole",
  "description": "A pungent and molten post-workout Brazilian dish featuring creamed corn and beurre-monte, diabetic-friendly and delicious.",
  "cuisine": "Brazilian",
  "diet": [
    "diabetic-friendly",
    "gluten-free"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "boneless chicken breast",
      "amount": "1 1/2 pounds",
      "notes": "cut into 1 inch pieces"
    },
    {
      "name": "creamed corn",
      "amount": "1 can",
      "notes": "low sodium"
    },
    {
      "name": "beurre-monte",
      "amount": "1/4 cup",
      "notes": "softened"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "coconut milk",
      "amount": "1 cup",
      "notes": "low fat"
    },
    {
      "name": "shredded cheese",
      "amount": "1 cup",
      "notes": "reduced fat"
    },
    {
      "name": "dried oregano",
      "amount": "1 teaspoon",
      "notes": "freshly ground"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon",
      "notes": "or to taste"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon",
      "notes": "or to taste"
    }
  ],
  "instructions": [
    "Preheat oven to 375 degrees Fahrenheit.",
    "In a large skillet, cook the chicken over medium-high heat until browned.",
    "Add the onion and garlic to the skillet and cook until the onion is translucent.",
    "In a large bowl, combine the cooked chicken, creamed corn, beurre-monte, coconut milk, shredded cheese, dried oregano, salt, and black pepper.",
    "Mix well to combine.",
    "Transfer the mixture to a 9x13 inch baking dish.",
    "Bake for 25 minutes or until the cheese is melted and bubbly.",
    "Remove from the oven and let rest for 5 minutes before serving."
  ],
