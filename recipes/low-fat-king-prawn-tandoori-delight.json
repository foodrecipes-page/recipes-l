{
  "title": "Low-Fat King Prawn Tandoori Delight",
  "description": "A sweet and creamy Jamaican-inspired dish featuring low-fat king prawns in a tandoor-style preparation perfect for date nights or special occasions.",
  "cuisine": "Jamaican",
  "diet": [
