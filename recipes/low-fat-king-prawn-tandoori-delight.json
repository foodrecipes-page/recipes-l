  "ingredients": [
    {
      "name": "king prawns",
      "amount": "12-16 pcs",
      "notes": "peeled and deveined"
    },
    {
      "name": "tomato paste",
      "amount": "3 tbsp"
    },
    {
      "name": "low-fat mayonnaise",
      "amount": "2 tbsp"
    },
    {
      "name": "unsweetened condensed milk",
      "amount": "2 tbsp"
    },
    {
      "name": "sweet corn kernels",
      "amount": "1 cup",
      "notes": "fresh or frozen"
    },
    {
      "name": "lime juice",
      "amount": "1 tbsp"
    },
    {
      "name": "dates, finely chopped",
      "amount": "4-5 pcs"
    },
    {
      "name": "ginger paste (ground ginger)",
      "amount": "1 tsp"
    },
    {
      "name": "all-purpose flour",
      "amount": "1 tbsp"
    },
    {
      "name": "turmeric powder",
      "amount": "1/2 tsp"
    },
    {
      "name": "cayenne pepper",
      "amount": "1/4 tsp"
    },
    {
      "name": "salt",
      "amount": "pinch"
    }
  ],
  "instructions": [
    "Blend all ingredients except prawns and corn in a food processor until smooth.",
    "Heat olive oil in a large skillet over medium heat. Add flour, turmeric powder, cayenne pepper, and salt to the pan, stirring for about 1 minute.",
    "Add blended mixture and corn kernels, cooking for another 2 minutes or until heated through.",
    "Gently add prawns into the skillet without overcrowding. Cook for about 3-4 minutes per side or until fully cooked.",
    "Serve hot with a garnish of finely chopped dates on top."
  ],
