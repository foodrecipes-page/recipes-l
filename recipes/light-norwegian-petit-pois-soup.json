{
  "title": "Light Norwegian Petit Pois Soup",
  "description": "A bright, mild soup made from petit pois (snow peas) simmered with a quick deglaze for depth, perfect for meal prep and eggfree friendly.",
  "cuisine": "Norwegian",
  "diet": [
    "vegetarian"
