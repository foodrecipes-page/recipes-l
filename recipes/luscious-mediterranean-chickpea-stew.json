{
  "title": "Luscious Mediterranean Chickpea Stew",
  "description": "A buttery, fluffy stew bursting with Mediterranean flavors and anti-inflammatory ingredients, perfect for a comforting dinner.",
  "cuisine": "Mediterranean",
  "diet": [
    "anti-inflammatory",
    "vegetarian"
  ],
