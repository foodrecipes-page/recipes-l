    {
      "name": "chickpeas",
      "amount": "400g drained (1 can)",
      "notes": "canned, rinsed and drained"
    },
    {
      "name": "olive oil",
      "amount": "2 tbsp"
    },
    {
      "name": "onion",
      "amount": "1 medium, diced"
    },
    {
      "name": "garlic",
      "amount": "3 cloves, minced"
    },
    {
      "name": "cherry tomatoes",
      "amount": "200g, halved"
    },
    {
      "name": "spinach",
      "amount": "150g, fresh"
    },
    {
      "name": "vegetable broth",
      "amount": "2 cups (480ml)",
      "notes": "low sodium"
    },
    {
      "name": "bouquet garni",
      "amount": "1 tsp thyme, 1 tsp rosemary, 1 bay leaf",
      "notes": "fresh herbs, tied together"
    },
    {
      "name": "lemon zest",
      "amount": "1 tsp"
    },
    {
      "name": "salt",
      "amount": "1 tsp"
    },
    {
      "name": "ground cumin",
      "amount": "1 tsp"
    },
    {
      "name": "ground coriander",
      "amount": "1 tsp"
    }
  ],
  "instructions": [
    "Heat a pressure cooker on medium, add olive oil and sauté onion until translucent.",
    "Add garlic and cook for 30 seconds until fragrant.",
    "Stir in cumin, coriander, and sauté for another minute.",
    "Add chickpeas, cherry tomatoes, spinach, and bouquet garni.",
    "Pour in broth, season with salt, and secure the lid.",
    "Cook on high pressure for 10 minutes, then natural release for 10 minutes.",
    "Open the lid, remove the bouquet garni, stir in lemon zest.",
    "Taste and adjust seasoning, serve hot over quinoa or crusty bread."
  ],
