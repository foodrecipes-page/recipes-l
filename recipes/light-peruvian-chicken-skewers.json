{
  "title": "Light Peruvian Chicken Skewers",
  "description": "A floral and light Peruvian dish featuring green olives and bhuna, perfect for a gluten-free friendly dinner. The combination of flavors and textures creates an indulgent yet refreshing experience.",
  "cuisine": "Peruvian",
  "diet": [
    "gluten-free"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "boneless, skinless chicken breast",
      "amount": "1.5 pounds",
      "notes": "cut into 1-inch pieces"
    },
    {
      "name": "green olives",
      "amount": "1/2 cup",
      "notes": "pitted"
    },
    {
      "name": "bhuna spice mix",
      "amount": "2 tablespoons"
    },
    {
      "name": "fresh cilantro",
      "amount": "1/4 cup",
      "notes": "chopped"
    },
    {
      "name": "fresh lime juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "gluten-free soy sauce",
      "amount": "1 tablespoon"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "ginger",
      "amount": "1-inch piece",
      "notes": "grated"
    },
    {
      "name": "bamboo skewers",
      "amount": "10-12",
      "notes": "soaked in water for 30 minutes"
    },
    {
      "name": "salt",
      "amount": "to taste"
    },
    {
      "name": "pepper",
      "amount": "to taste"
    }
  ],
  "instructions": [
    "Preheat grill to medium-high heat (400°F).",
    "In a large bowl, whisk together bhuna spice mix, gluten-free soy sauce, lime juice, garlic, and ginger.",
    "Add the chicken to the bowl and marinate for at least 30 minutes, or up to 2 hours in the refrigerator.",
    "Thread the marinated chicken, green olives, and cilantro onto the bamboo skewers.",
    "Season with salt and pepper to taste.",
    "Grill the skewers for 10-12 minutes, or until the chicken is cooked through.",
    "Serve immediately, garnished with additional cilantro if desired.",
    "Rest the skewers for 5 minutes before serving to allow the juices to redistribute."
  ],
