      "amount": "2 tablespoons"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "mushrooms",
      "amount": "1 cup",
      "notes": "sliced"
    },
    {
      "name": "bell peppers",
      "amount": "1 cup",
      "notes": "sliced"
    },
    {
      "name": "tomato paste",
      "amount": "2 tablespoons"
    },
    {
      "name": "vegetable broth",
      "amount": "1 cup"
    },
    {
      "name": "paprika",
      "amount": "1 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Heat the olive oil in a large skillet over medium-high heat.",
    "Add the chopped onion and cook until translucent, about 3 minutes.",
    "Add the minced garlic and cook for an additional minute.",
    "Add the sliced mushrooms and bell peppers, cook until they start to soften.",
    "Add the tempeh and cook until it is golden brown on all sides.",
    "Add the tomato paste, paprika, salt, and black pepper, stir to combine.",
    "Pour in the vegetable broth and bring the mixture to a simmer.",
    "Reduce the heat to low and let cook for 10 minutes, stirring occasionally.",
    "Serve the stir-fry hot, garnished with fresh parsley if desired."
  ],
