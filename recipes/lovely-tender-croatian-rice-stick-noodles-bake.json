      "amount": "1 tsp"
    },
    {
      "name": "salt",
      "amount": "1 tsp"
    },
    {
      "name": "black pepper",
      "amount": "1/2 tsp"
    }
  ],
  "instructions": [
    "Preheat the oven to 375 degrees.",
    "Cook the rice stick noodles according to package instructions and set aside.",
    "In a large skillet, heat the olive oil over medium heat and saute the mushrooms and onions until tender.",
    "Add the garlic, tomato paste, and nutritional yeast to the skillet and cook for an additional 2 minutes.",
    "In a large bowl, combine the cooked noodles, skillet mixture, and vegetable broth, and stir until well combined.",
    "Season with salt and black pepper to taste.",
    "Transfer the noodle mixture to a baking dish and bake for 20 minutes.",
    "Remove from the oven and let cool for a few minutes before serving."
