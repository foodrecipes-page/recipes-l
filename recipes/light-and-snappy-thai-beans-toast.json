  "ingredients": [
    {
      "name": "White Navy Beans",
      "amount": "1 cup dried"
    },
    {
      "name": "Whole Wheat Bread",
      "amount": "2 slices"
    },
    {
      "name": "Coconut Oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "Green Chilies",
      "amount": "2",
      "notes": "sliced"
    },
    {
      "name": "Garlic Cloves",
      "amount": "2",
      "notes": "minced"
    },
    {
      "name": "Soy Sauce",
      "amount": "1 tablespoon"
    },
    {
      "name": "Fresh Cilantro",
      "amount": "1/4 cup",
      "notes": "chopped"
    },
    {
      "name": "Lime Juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "Salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "Black Pepper",
      "amount": "1/4 teaspoon"
    }
  ],
  "instructions": [
    "Preheat the oven to 375°F (190°C).",
    "In a medium saucepan, heat the coconut oil over medium heat.",
    "Add the sliced green chilies and cook for 2 minutes.",
    "Add the minced garlic and cook for another minute.",
    "Add the dried navy beans to the saucepan and stir to combine.",
    "Pour in 4 cups of water and bring to a boil.",
    "Reduce the heat to low and simmer for 20 minutes, or until the beans are tender.",
    "Meanwhile, toast the whole wheat bread slices in the oven for 2-3 minutes.",
    "Mash the cooked navy beans with a fork to create a coarse paste.",
    "Spread the bean paste on the toasted bread slices.",
    "Drizzle the soy sauce and lime juice over the top of each slice.",
    "Sprinkle chopped cilantro and a pinch of salt and pepper over the top.",
    "Serve immediately and enjoy."
  ],
