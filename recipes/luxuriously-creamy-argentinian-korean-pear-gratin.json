  ],
  "instructions": [
    "Preheat the oven to 375 degrees Fahrenheit",
    "In a large bowl, whisk together miso paste, olive oil, garlic, salt, and black pepper to make the marinate",
    "Add the sliced Korean pear to the marinate and toss to coat",
    "Arrange the marinated pear slices in a single layer in a baking dish",
    "Pour the heavy cream over the pear slices",
    "Sprinkle the grated cheese over the cream",
    "Top with chopped fresh thyme",
    "Bake for 25 minutes or until the top is golden brown and the cream is bubbly",
    "Remove from the oven and let it rest for 5 minutes before serving"
  ],
