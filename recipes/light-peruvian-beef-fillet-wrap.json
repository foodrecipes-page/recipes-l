{
  "title": "Light Peruvian Beef Fillet Wrap",
  "description": "A sweet and light Peruvian dish featuring beef fillet, leaf wrap steam, and Buddhist temple friendly ingredients, perfect for a snack or lunch",
  "cuisine": "Peruvian",
  "diet": [
    "gluten-free",
