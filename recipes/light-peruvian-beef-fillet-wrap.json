      "name": "beef fillet",
      "amount": "1 pound",
      "notes": "cut into thin strips"
    },
    {
      "name": "banana leaves",
      "amount": "4 large leaves"
    },
    {
      "name": "lime juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "olive oil",
      "amount": "1 tablespoon"
    },
    {
      "name": "garlic",
      "amount": "2 cloves",
      "notes": "minced"
    },
    {
      "name": "ginger",
      "amount": "1 tablespoon",
      "notes": "grated"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Preheat a steamer basket over boiling water.",
    "In a small bowl, whisk together lime juice, olive oil, garlic, and ginger.",
    "Add the beef strips to the bowl and marinate for 10 minutes.",
    "Cut the banana leaves into large squares and place a beef strip in the center of each square.",
    "Fold the banana leaves over the beef to form a tight package and place in the steamer basket.",
    "Steam the beef packages for 10 minutes or until cooked through.",
    "Serve the beef wraps hot with a sprinkle of salt and pepper."
  ],
