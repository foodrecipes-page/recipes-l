    },
    {
      "name": "2 oz doner meat (turkey or chicken)",
      "amount": "2 oz, sliced thinly"
    },
    {
      "name": "1 tbsp fresh garlic paste",
      "amount": "1 tbsp"
    },
    {
      "name": "Juice of 1 lemon",
      "amount": "Juice of 1 lemon"
    },
    {
      "name": "2 sprigs fresh parsley",
      "amount": "2 sprigs (chopped)"
    },
    {
      "name": "1/4 cup diced pickled red onion",
      "amount": "1/4 cup"
    },
    {
      "name": "Salt and pepper to taste",
      "amount": "To taste"
    }
  ],
  "instructions": [
    "Slice the baguette or pita bread into rounds.",
    "Place a slice of doner meat on each piece of bread.",
    "Spread garlic paste over the top of the meat.",
    "Squeeze lemon juice evenly over the garlic mixture.",
    "Chop parsley and sprinkle it over the meat.",
    "Add diced pickled red onion on top.",
    "Season with salt and pepper.",
    "Serve immediately."
