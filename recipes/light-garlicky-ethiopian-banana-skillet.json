{
  "title": "Light Garlicky Ethiopian Banana Skillet",
  "description": "A quick and easy Ethiopian dish featuring bananas, with a light garlicky flavor and a shattering texture, served in a tagliere vessel.",
  "cuisine": "Ethiopian",
  "diet": [
    "kosher"
  ],
  "meal": "snack",
  "ingredients": [
    {
      "name": "ripe bananas",
      "amount": "4",
      "notes": "sliced"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "berbere spice",
      "amount": "1 teaspoon",
      "notes": "Ethiopian spice mix"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "vegetable oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "fresh cilantro",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Heat the oil in a large tagliere over medium heat.",
    "Add the chopped onion and cook until it is translucent.",
    "Add the minced garlic and cook for 1 minute, until fragrant.",
    "Add the sliced bananas and cook for 2 minutes, until they start to brown.",
    "Add the berbere spice, salt, and black pepper, and stir to combine.",
    "Cook for an additional 2 minutes, until the bananas are lightly browned and the flavors are combined.",
    "Stir in the chopped cilantro.",
    "Serve the skillet hot, directly from the tagliere."
  ],
