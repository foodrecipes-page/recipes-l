{
  "title": "Luscious Silky Mediterranean Seafood Risotto",
  "description": "A roasted, silky midnight-craving dish featuring a dairy‑free, seafood stock risotto steamed to perfection in a bamboo steamer.",
  "cuisine": "Mediterranean",
  "diet": [
    "dairy-free",
    "vegetarian"
