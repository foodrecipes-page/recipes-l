      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "turkish red pepper",
      "amount": "1 teaspoon",
      "notes": "crushed"
    },
    {
      "name": "chicken broth",
      "amount": "2 cups",
      "notes": "low sodium"
    },
    {
