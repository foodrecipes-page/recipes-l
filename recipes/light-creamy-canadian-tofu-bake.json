  "ingredients": [
    {
      "name": "silken tofu",
      "amount": "1 14-ounce package",
      "notes": ""
    },
    {
      "name": "plain whole wheat bread",
      "amount": "1 cup cubed",
      "notes": ""
    },
    {
      "name": "fresh dill",
      "amount": "2 tablespoons chopped",
      "notes": "chopped fresh or 1 teaspoon dried"
    },
    {
      "name": "fresh chives",
      "amount": "2 tablespoons chopped",
      "notes": "chopped fresh or 1 teaspoon dried"
    },
    {
      "name": "lemon juice",
      "amount": "2 tablespoons",
      "notes": "freshly squeezed"
    },
    {
      "name": "apple cider vinegar",
      "amount": "1 tablespoon",
      "notes": "adjust to taste"
    },
    {
      "name": "unsweetened almond milk",
      "amount": "1 cup",
      "notes": ""
    },
    {
      "name": "tempering chocolate",
      "amount": "2 tablespoons",
