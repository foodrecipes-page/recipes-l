      "amount": "20 g",
      "notes": "for roasting"
    },
    {
      "name": "fresh lemongrass stalk",
      "amount": "1 stalk",
      "notes": "crushed and minced"
    },
    {
      "name": "garlic cloves",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "red chili",
      "amount": "1 small",
      "notes": "sliced"
    },
